{
  "name": "mcp-stack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "build": "echo 'no build at root; each app builds via wrangler'",
    "deploy:oura": "pnpm --filter oura-mcp deploy",
    "deploy:gmail": "pnpm --filter gmail-mcp deploy",
    "deploy:trip": "pnpm --filter trip-mcp deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.18",
      "fast-uri": ">=3.1.2",
      "ip-address": ">=10.1.1"
    }
  }
}
