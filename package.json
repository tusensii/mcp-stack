{
  "name": "mcp-stack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "build": "echo 'no build at root; each app builds via wrangler'",
    "deploy:oura": "pnpm --filter oura-mcp deploy",
    "deploy:otf": "pnpm --filter otf-mcp deploy",
    "deploy:therapy": "pnpm --filter therapy-mcp deploy",
    "deploy:gmail": "pnpm --filter gmail-mcp deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
